# LocalVoice Configuration
# Copy to .env and customize as needed

# ─── Whisper STT (compat shim + whisper.cpp backend) ───
# Model size: tiny, base, small, medium, large-v2, large-v3
WHISPER_MODEL=small
# Device hint: vulkan (AMD iGPU) or cpu fallback
WHISPER_DEVICE=vulkan
# Compute type compatibility hint (kept for API compatibility)
WHISPER_COMPUTE_TYPE=int8
# CPU threads for inference
WHISPER_THREADS=4

# ─── Piper TTS (fast, real-time) ──────────────────
# Voice model name (see: https://rhasspy.github.io/piper-samples/)
PIPER_VOICE=en_US-lessac-medium

# ─── Parler-TTS (high quality, slow) ─────────────
# Only used with: docker compose --profile quality-tts up
PARLER_MODEL=parler-tts/parler_tts_mini_v0.1
PARLER_DESCRIPTION=A female speaker delivers a slightly expressive and animated speech.
PARLER_THREADS=6
